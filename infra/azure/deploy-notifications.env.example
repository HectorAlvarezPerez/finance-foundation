# Variables opcionales para notificaciones operativas de deploy
# Estas variables no forman parte del runtime de backend/frontend.

# Webhook de Slack para publicar notificaciones en un canal concreto.
SLACK_WEBHOOK_URL=

# Azure OpenAI reutiliza las credenciales base ya existentes; aquí solo se define
# el deployment específico para el resumen narrativo de deploy.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_DEPLOY_SUMMARY_DEPLOYMENT=

# Si Langfuse está habilitado, el script intenta obtener el prompt desde Langfuse
# y además registra trazas de generación para la notificación de deploy.
# Si falta esta variable, usa por defecto: deploy_summary_notification
LANGFUSE_DEPLOY_SUMMARY_PROMPT_NAME=deploy_summary_notification

# Opcional en workflows: permite resolver la PR mergeada asociada al commit.
# En scripts locales no hace falta.
GH_TOKEN=
