APP_ENV=production
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<database>?sslmode=require
FRONTEND_ORIGIN=https://app.example.com
SESSION_SECRET_KEY=replace-me-with-a-random-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
ALLOW_DEV_USER_HEADER=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/api/v1/auth/google/callback
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_PDF_PARSER_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
