APP_ENV=development
AUTH_MODE=local

# Local development defaults
DATABASE_URL=sqlite:///./dev-app.db
SESSION_SECRET_KEY=change-me-for-real
SESSION_COOKIE_NAME=finance_foundation_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=604800
ALLOW_DEV_USER_HEADER=true
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3100

# Google OAuth v1
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_OAUTH_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration

# Microsoft Entra External ID
# Optional future path if we later want to centralize auth there.
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Prefer setting ENTRA_METADATA_URL directly from the OpenID Connect discovery endpoint
# of your external tenant / user flow. Leave ENTRA_AUTHORITY_URL empty if you do that.
ENTRA_METADATA_URL=

# Optional alternative to ENTRA_METADATA_URL if you prefer to compose the
# discovery document URL as `${ENTRA_AUTHORITY_URL}/.well-known/openid-configuration`.
ENTRA_AUTHORITY_URL=

# Must match the redirect URI registered in the Entra app registration.
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/entra/callback

# Optional hint used by the Google CTA to push users into the Google provider.
ENTRA_GOOGLE_DOMAIN_HINT=google.com
